  "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script src='https://blog.meekdai.com/Gmeek/plugins/lightbox.js'></script><script>document.addEventListener('DOMContentLoaded',function(){\nvar bar=document.createElement('div');\nbar.style.cssText='position:fixed;top:0;left:0;height:3px;width:0%;background:linear-gradient(90deg,#0969da,#8250df);z-index:9999;transition:width 0.1s';\ndocument.body.appendChild(bar);\nwindow.addEventListener('scroll',function(){var st=window.scrollY||document.documentElement.scrollTop;var dh=document.documentElement.scrollHeight-document.documentElement.clientHeight;bar.style.width=(dh>0?Math.round(st/dh*100):0)+'%'});\ndocument.querySelectorAll('pre').forEach(function(pre){\nvar code=pre.querySelector('code');if(!code)return;\nvar m=(code.className||'').match(/language-(\\w+)/);\nif(m){var tag=document.createElement('span');tag.textContent=m[1];tag.style.cssText='position:absolute;top:8px;right:76px;font-size:11px;color:#888;font-family:monospace;text-transform:uppercase;background:#e8e8e8;padding:2px 8px;border-radius:4px';pre.style.position='relative';pre.appendChild(tag)}\nvar fsBtn=document.createElement('button');fsBtn.textContent='⛶';fsBtn.title='全屏';fsBtn.style.cssText='position:absolute;top:8px;right:8px;font-size:13px;color:#888;background:#e8e8e8;border:none;padding:2px 8px;border-radius:4px;cursor:pointer';fsBtn.onclick=function(){if(!document.fullscreenElement){pre.requestFullscreen()}else{document.exitFullscreen()}};pre.style.position='relative';pre.appendChild(fsBtn);\nvar lines=code.innerHTML.split('\\n');\nif(lines.length>20){var orig=code.innerHTML;code.innerHTML=lines.slice(0,20).join('\\n');var more=document.createElement('div');more.innerHTML='<span style=\"color:#0969da;cursor:pointer;font-size:13px\">… 展开剩余 '+(lines.length-20)+' 行</span>';more.onclick=function(){code.innerHTML=orig;more.remove()};pre.appendChild(more)}\n});\ndocument.querySelectorAll('a[href^=\"http\"]').forEach(function(a){if(!a.href.includes('luliy6.github.io'))a.target='_blank'});\ndocument.querySelectorAll('#postBody img').forEach(function(img){img.loading='lazy';img.style.transition='opacity 0.3s';img.style.opacity='0';img.onload=function(){img.style.opacity='1'};if(img.complete)img.style.opacity='1';var t;img.addEventListener('touchstart',function(){t=setTimeout(function(){alert('可以长按保存此图片')},600)});img.addEventListener('touchend',function(){clearTimeout(t)})});\nvar pbody=document.getElementById('postBody');\nif(pbody){\nvar wc=pbody.innerText.length;var mins=Math.max(1,Math.round(wc/300));\nvar rtag=document.createElement('p');rtag.innerHTML='预计阅读：约 '+mins+' 分钟 &nbsp;|&nbsp; 共 '+wc+' 字';rtag.style.cssText='color:#888;font-size:13px;margin-bottom:1.5rem';pbody.insertBefore(rtag,pbody.firstChild);\ndocument.querySelectorAll('#postBody h2').forEach(function(h,i){if(!h.textContent.match(/^\\d+\\./))h.textContent=(i+1)+'. '+h.textContent});\ndocument.querySelectorAll('#postBody h1,#postBody h2,#postBody h3').forEach(function(h){h.style.cursor='pointer';h.title='点击复制链接';h.onclick=function(){var url=location.href.split('#')[0]+'#'+h.id;navigator.clipboard&&navigator.clipboard.writeText(url);var tip=document.createElement('span');tip.textContent=' 已复制!';tip.style.cssText='font-size:12px;color:#1f883d;font-weight:normal';h.appendChild(tip);setTimeout(function(){tip.remove()},2000)}});\ndocument.addEventListener('copy',function(){var sel=window.getSelection().toString();if(sel.length>10){setTimeout(function(){try{navigator.clipboard.writeText(sel+'\\n\\n转载请注明出处：https://luliy6.github.io')}catch(e){}},0)}});\nvar printBtn=document.createElement('button');printBtn.textContent='打印';printBtn.style.cssText='position:fixed;bottom:136px;right:24px;width:44px;height:44px;border-radius:50%;border:none;background:#1f883d;color:#fff;font-size:12px;cursor:pointer;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2)';document.body.appendChild(printBtn);printBtn.onclick=function(){window.print()};\nvar readBtn=document.createElement('button');readBtn.textContent='朗读';readBtn.style.cssText='position:fixed;bottom:192px;right:24px;width:44px;height:44px;border-radius:50%;border:none;background:#bc4c00;color:#fff;font-size:12px;cursor:pointer;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2)';document.body.appendChild(readBtn);var reading=false;readBtn.onclick=function(){if(!reading){var utter=new SpeechSynthesisUtterance(pbody.innerText);utter.lang='zh-CN';speechSynthesis.speak(utter);readBtn.textContent='停止';reading=true;utter.onend=function(){readBtn.textContent='朗读';reading=false}}else{speechSynthesis.cancel();readBtn.textContent='朗读';reading=false}};\nvar noticed=false;window.addEventListener('scroll',function(){var sh=document.documentElement.scrollHeight;var ch=document.documentElement.clientHeight;if(!noticed&&window.scrollY+ch>=sh-50){noticed=true;var tip=document.createElement('div');tip.textContent='已读完！🎉';tip.style.cssText='position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#0969da;color:#fff;padding:16px 32px;border-radius:12px;font-size:20px;z-index:9999';document.body.appendChild(tip);setTimeout(function(){tip.remove()},2500)}});\n}\nvar topBtn=document.createElement('button');topBtn.textContent='↑';topBtn.style.cssText='position:fixed;bottom:24px;right:24px;width:44px;height:44px;border-radius:50%;border:none;background:#0969da;color:#fff;font-size:20px;cursor:pointer;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2);display:none';document.body.appendChild(topBtn);topBtn.onclick=function(){window.scrollTo({top:0,behavior:'smooth'})};window.addEventListener('scroll',function(){topBtn.style.display=window.scrollY>300?'block':'none'});\ndocument.addEventListener('dblclick',function(e){if(e.target.tagName!='A'&&e.target.tagName!='BUTTON'&&e.target.tagName!='INPUT'){window.scrollTo({top:0,behavior:'smooth'})}});\nvar fontBtns=document.createElement('div');fontBtns.style.cssText='position:fixed;bottom:248px;right:18px;display:flex;flex-direction:column;gap:4px;z-index:999';fontBtns.innerHTML='<button onclick=\"window._fs=Math.min(28,(window._fs||18)+2);var p=document.getElementById(\\'postBody\\');if(p)p.style.fontSize=window._fs+\\'px\\'\" style=\"width:44px;height:22px;border-radius:6px;border:none;background:#f0f0f0;cursor:pointer\">A+</button><button onclick=\"window._fs=Math.max(14,(window._fs||18)-2);var p=document.getElementById(\\'postBody\\');if(p)p.style.fontSize=window._fs+\\'px\\'\" style=\"width:44px;height:22px;border-radius:6px;border:none;background:#f0f0f0;cursor:pointer\">A-</button>';document.body.appendChild(fontBtns);\nvar focusBtn=document.createElement('button');focusBtn.textContent='专注';focusBtn.style.cssText='position:fixed;bottom:300px;right:18px;width:44px;height:22px;border-radius:6px;border:none;background:#f0f0f0;font-size:11px;cursor:pointer;z-index:999';document.body.appendChild(focusBtn);var focused=false;focusBtn.onclick=function(){focused=!focused;var nav=document.querySelector('.Header')||document.querySelector('header');if(nav)nav.style.display=focused?'none':'';focusBtn.textContent=focused?'退出':'专注'};\nvar searchBtn=document.createElement('button');searchBtn.textContent='S';searchBtn.title='搜索 (/)';searchBtn.style.cssText='position:fixed;bottom:80px;right:24px;width:44px;height:44px;border-radius:50%;border:none;background:#8250df;color:#fff;font-size:15px;font-weight:bold;cursor:pointer;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2)';document.body.appendChild(searchBtn);\nvar overlay=document.createElement('div');overlay.style.cssText='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:1000;align-items:flex-start;justify-content:center;padding-top:80px';overlay.innerHTML='<div style=\"background:#fff;border-radius:12px;padding:20px;width:90%;max-width:500px\"><input id=\"s-input\" placeholder=\"搜索文章...\" style=\"width:100%;padding:10px;font-size:16px;border:1px solid #ddd;border-radius:8px;outline:none\"><div id=\"s-results\" style=\"margin-top:12px;max-height:360px;overflow-y:auto\"></div></div>';document.body.appendChild(overlay);\nfunction openSearch(){overlay.style.display='flex';setTimeout(function(){document.getElementById('s-input').focus()},100)}\nsearchBtn.onclick=openSearch;overlay.onclick=function(e){if(e.target===overlay)overlay.style.display='none'};\ndocument.addEventListener('keydown',function(e){if(e.key==='/'&&document.activeElement.tagName!='INPUT'){e.preventDefault();openSearch()}if(e.key==='Escape')overlay.style.display='none';if((e.key==='t'||e.key==='T')&&document.activeElement.tagName!='INPUT')window.scrollTo({top:0,behavior:'smooth'})});\ndocument.getElementById('s-input').addEventListener('input',function(){var q=this.value.trim().toLowerCase();var res=document.getElementById('s-results');if(!q){res.innerHTML='';return}fetch('/postList.json').then(function(r){return r.json()}).then(function(posts){var hits=posts.filter(function(p){return p.title.toLowerCase().includes(q)});res.innerHTML=hits.length?hits.map(function(p){return'<a href=\"'+p.link+'\" style=\"display:block;padding:10px;border-bottom:1px solid #eee;color:#0969da;text-decoration:none\">'+p.title+'</a>'}).join(''):'<p style=\"color:#888;padding:10px\">没有找到相关文章</p>'})});\n});\ndocument.title=document.title;document.addEventListener('visibilitychange',function(){document.title=document.hidden?'👋 快回来！':document.title.replace('👋 快回来！','')});\nvar konamiSeq=[38,38,40,40,37,39,37,39,66,65];var konamiIdx=0;document.addEventListener('keydown',function(e){if(e.keyCode===konamiSeq[konamiIdx]){konamiIdx++;if(konamiIdx===konamiSeq.length){konamiIdx=0;alert('🎉 彩蛋触发！你发现了隐藏的秘密！')}else{}}else{konamiIdx=0}});\n});</script>",
  "indexScript": "<script>document.addEventListener('DOMContentLoaded',function(){\nvar av=document.querySelector('.avatar');\nif(av){av.style.cursor='pointer';av.onclick=function(){window.open('https://github.com/luliy6')}}\nvar items=document.querySelectorAll('.post-item');\nitems.forEach(function(el,i){el.style.animationDelay=(i*0.07)+'s'});\nvar el=document.querySelector('.blogTitle p')||document.querySelector('p.f4');\nif(el){var txt=el.textContent;el.textContent='';var i=0;(function type(){if(i<txt.length){el.textContent+=txt[i++];setTimeout(type,60)}})()}\nvar h=new Date().getHours();\nvar greet=h<6?'夜深了，注意休息':h<12?'早上好！':h<14?'中午好！':h<18?'下午好！':'晚上好！';\nvar gtag=document.createElement('div');gtag.textContent=greet+' 欢迎来到 Luliy\\'s Blog';gtag.style.cssText='text-align:center;font-size:13px;color:#888;margin-bottom:8px';\nvar wrap=document.querySelector('.container-lg')||document.body;wrap.insertBefore(gtag,wrap.firstChild);\nvar rndBtn=document.createElement('button');rndBtn.textContent='随机文章';rndBtn.style.cssText='display:block;margin:8px auto;padding:6px 18px;border-radius:20px;border:1px solid #0969da;background:transparent;color:#0969da;cursor:pointer;font-size:13px';rndBtn.onclick=function(){fetch('/postList.json').then(function(r){return r.json()}).then(function(posts){if(posts.length){var p=posts[Math.floor(Math.random()*posts.length)];location.href=p.link}})};wrap.insertBefore(rndBtn,gtag.nextSibling);\ndocument.addEventListener('keydown',function(e){if(e.key==='ArrowLeft')history.back();if(e.key==='ArrowRight')history.forward()});\nvar clock=document.createElement('div');clock.style.cssText='text-align:center;font-size:12px;color:#aaa;margin-bottom:4px';wrap.insertBefore(clock,gtag);setInterval(function(){var now=new Date();clock.textContent=now.toLocaleTimeString('zh-CN')},1000);\n});</script>"
