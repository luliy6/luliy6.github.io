  "indexScript": "<script>document.addEventListener('DOMContentLoaded',function(){var avatar=document.querySelector('.avatar');if(avatar){avatar.style.cursor='pointer';avatar.onclick=function(){window.open('https://github.com/luliy6','_blank','noopener')};avatar.addEventListener('mouseenter',function(){avatar.style.transform='scale(1.03)'});avatar.addEventListener('mouseleave',function(){avatar.style.transform='scale(1)'})}var titleEl=document.querySelector('.blogTitle h1,.blogTitle a,.blogTitle p,h1.f1,h1');if(titleEl){titleEl.classList.add('rainbow-title')}var banner=document.createElement('div');banner.className='home-announce';banner.innerHTML='<strong>置顶公告</strong><span>最新动态加载中…</span>';document.body.insertBefore(banner,document.body.firstChild);fetch('/postList.json',{cache:'no-store'}).then(function(r){return r.json()}).then(function(posts){if(!Array.isArray(posts)||!posts.length)return;var latest=posts[0]||{};var title=latest.title||latest.name||latest.postTitle||'最新文章';var link=latest.link||latest.url||'#';banner.innerHTML='<strong>置顶公告</strong><span>最新动态：<a href=\"'+link+'\">'+title+'</a></span>'}).catch(function(){banner.innerHTML='<strong>置顶公告</strong><span>欢迎来到 Luliy 的博客，持续更新中。</span>'});var tagPage=/tag/i.test(location.pathname)||document.querySelector('.tag-cloud,.tag-list,.tag-list-page,.tag-item');if(tagPage){var tagLinks=Array.from(document.querySelectorAll('.tag-cloud a,.tag-list a,a[href*=\"/tag/\"]'));if(tagLinks.length){var maxCount=1;var tagData=tagLinks.map(function(a){var text=(a.textContent||'').trim();var count=1;var m=(a.dataset&&a.dataset.count&&String(a.dataset.count).match(/\\d+/))||text.match(/\\((\\d+)\\)$/)||text.match(/(\\d+)$/);if(m)count=parseInt(m[1]||m[0],10)||1;maxCount=Math.max(maxCount,count);return{a:a,count:count}});tagData.forEach(function(item){var size=12+Math.round((item.count/maxCount)*12);item.a.style.fontSize=size+'px';item.a.style.fontWeight=item.count===maxCount?'700':'500';item.a.style.display='inline-block';item.a.style.margin='.35rem .45rem';item.a.style.padding='.45rem .75rem';item.a.style.borderRadius='999px';item.a.style.background='rgba(9,105,218,.08)';item.a.style.transition='transform .2s ease,background .2s ease';item.a.onmouseenter=function(){item.a.style.transform='translateY(-2px)';item.a.style.background='rgba(9,105,218,.14)'};item.a.onmouseleave=function(){item.a.style.transform='translateY(0)';item.a.style.background='rgba(9,105,218,.08)'}})}}var items=document.querySelectorAll('.post-item');items.forEach(function(el,i){el.style.animationDelay=(i*0.07)+'s'});var canvas=document.createElement('canvas');canvas.id='petals-canvas';document.body.appendChild(canvas);var ctx=canvas.getContext('2d');if(!ctx)return;function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight}resize();window.addEventListener('resize',resize);var petals=[];for(var p=0;p<28;p++){petals.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:Math.random()*5+3,speed:Math.random()*0.7+0.25,drift:Math.random()*0.6-0.3,opacity:Math.random()*0.35+0.18,color:Math.random()>0.5?'#ffb7c5':'#ffffff'})}function drawPetal(p){ctx.save();ctx.globalAlpha=p.opacity;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=p.color;ctx.fill();ctx.restore()}function animate(){ctx.clearRect(0,0,canvas.width,canvas.height);petals.forEach(function(p){drawPetal(p);p.y+=p.speed;p.x+=p.drift;if(p.y>canvas.height+10){p.y=-10;p.x=Math.random()*canvas.width}});requestAnimationFrame(animate)}animate()});</script>"
