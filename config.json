ntent=code.textContent.trim();(code.parentElement&&code.parentElement.tagName==='PRE'?code.parentElement:code).replaceWith(block);});if(mermaid.run){mermaid.run({querySelector:'.mermaid'});}else if(mermaid.init){mermaid.init(undefined,document.querySelectorAll('.mermaid'));}}if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){});}});</script><link rel='stylesheet' href='https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css'><style>body,#postBody{font-family:'LXGW WenKai','LXGW WenKai Screen',sans-serif}html{scroll-behavior:smooth}::selection{background:#f0b429;color:#000}a[target='_blank']::after{content:' ↗';font-size:0.75em;opacity:0.6}::-webkit-scrollbar{width:8px;height:8px}::-webkit-scrollbar-thumb{background:#8250df;border-radius:4px}::-webkit-scrollbar-track{background:transparent}.container-lg{max-width:960px!important}body{background-image:radial-gradient(rgba(9,105,218,0.1) 1px,transparent 1px);background-size:25px 25px}[data-color-mode=\"dark\"] body{background-image:radial-gradient(rgba(255,255,255,0.06) 1px,transparent 1px)}[data-color-mode=\"dark\"] pre{background:#1a1a2e!important;border:1px solid #2d2d4e!important}[data-color-mode=\"dark\"] #postBody code{background:#2a2a3e!important;color:#ff9a3c!important}[data-color-mode=\"dark\"] #postBody blockquote{background:rgba(130,80,223,0.12)!important;border-left-color:#8250df!important;color:#ccc!important}[data-color-mode=\"dark\"] #postBody table th{background:rgba(130,80,223,0.2)!important;color:#a78bfa!important}[data-color-mode=\"dark\"] #postBody td{border-color:rgba(255,255,255,0.06)!important}[data-color-mode=\"dark\"] #postBody tr:nth-child(even){background:rgba(255,255,255,0.03)!important}[data-color-mode=\"dark\"] #postBody tr:hover{background:rgba(130,80,223,0.1)!important}[data-color-mode=\"dark\"] .post-item{background:#1a1a2e!important}[data-color-mode=\"dark\"] .announce-bar{background:#3a1f6e!important}/* TOC夜间模式完美自适应 */.toc,.markdown-toc,#markdown-toc{position:fixed!important;right:20px!important;top:140px!important;width:240px!important;border:1px solid rgba(9,105,218,.16)!important;border-radius:12px!important;background:rgba(255,255,255,.85)!important;box-shadow:0 8px 28px rgba(9,105,218,.08)!important;padding:12px 14px!important;max-height:calc(100vh - 200px);overflow-y:auto;backdrop-filter:blur(10px);z-index:99}.toc a,.markdown-toc a,#markdown-toc a{display:block;border-radius:8px;padding:5px 8px;color:#57606a!important;text-decoration:none!important;line-height:1.5;transition:background .18s,color .18s;font-size:13px!important}.toc a:hover,.markdown-toc a:hover,#markdown-toc a:hover{background:rgba(9,105,218,.08);color:#0969da!important}.toc .active,.markdown-toc .active,#markdown-toc .active{background:rgba(240,180,41,.16);color:#bc4c00!important;font-weight:700}[data-color-mode=\"dark\"] .toc,[data-color-mode=\"dark\"] .markdown-toc,[data-color-mode=\"dark\"] #markdown-toc{background:rgba(26,26,46,0.88)!important;border:1px solid rgba(130,80,223,0.25)!important;box-shadow:0 8px 28px rgba(0,0,0,0.4)!important}[data-color-mode=\"dark\"] .toc a,[data-color-mode=\"dark\"] .markdown-toc a,[data-color-mode=\"dark\"] #markdown-toc a{color:#c9d1d9!important}[data-color-mode=\"dark\"] .toc a:hover,[data-color-mode=\"dark\"] .markdown-toc a:hover{background:rgba(130,80,223,0.2);color:#a78bfa!important}[data-color-mode=\"dark\"] .toc .active,[data-color-mode=\"dark\"] .markdown-toc .active{background:rgba(240,180,41,0.2)!important;color:#ff9a3c!important}.toc::-webkit-scrollbar,.markdown-toc::-webkit-scrollbar{width:4px;height:4px}.toc::-webkit-scrollbar-thumb,.markdown-toc::-webkit-scrollbar-thumb{background:#c0c0c0;border-radius:4px}.toc::-webkit-scrollbar-track,.markdown-toc::-webkit-scrollbar-track{background:#f0f0f0}[data-color-mode=\"dark\"] .toc::-webkit-scrollbar-thumb,[data-color-mode=\"dark\"] .markdown-toc::-webkit-scrollbar-thumb{background:#555}[data-color-mode=\"dark\"] .toc::-webkit-scrollbar-track,[data-color-mode=\"dark\"] .markdown-toc::-webkit-scrollbar-track{background:#2a2a2a}/* 首页注入样式（原indexStyle） */.announce-bar{background:#0969da;color:#fff;text-align:center;padding:12px;border-radius:10px;margin-bottom:25px;font-size:15px;box-shadow:0 4px 15px rgba(0,0,0,0.1);font-weight:bold;letter-spacing:1px}.post-item{border-radius:14px!important;position:relative;transition:transform 0.35s,box-shadow 0.35s;background:#fff;margin-bottom:20px;overflow:hidden}.post-item:nth-child(4n+1){border-left:4px solid #8250df}.post-item:nth-child(4n+2){border-left:4px solid #0969da}.post-item:nth-child(4n+3){border-left:4px solid #ff6b9d}.post-item:nth-child(4n+0){border-left:4px solid #f0b429}.post-item:hover{transform:translateY(-6px);box-shadow:0 12px 32px rgba(130,80,223,0.18)}.hitokoto-bar{background:linear-gradient(135deg,rgba(130,80,223,0.08),rgba(240,180,41,0.08));border:1px solid rgba(130,80,223,0.2);border-radius:12px;padding:16px 22px;margin-bottom:24px;text-align:center;font-size:15px;color:#555;font-style:italic}[data-color-mode=\"dark\"] .hitokoto-bar{background:rgba(130,80,223,0.1);color:#bbb;border-color:rgba(130,80,223,0.3)}canvas#petals-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}/* 聚合收藏夹样式 */.fav-tab-btn{padding:8px 16px;border:none;background:none;font-weight:bold;cursor:pointer;color:#57606a;border-radius:6px;transition:all 0.2s}.fav-tab-btn:hover{background:rgba(9,105,218,0.08);color:#0969da}.fav-tab-btn.active{color:#8250df!important;border-bottom:2px solid #8250df;border-radius:0}[data-color-mode=\"dark\"] .fav-tab-btn{color:#c9d1d9}[data-color-mode=\"dark\"] .fav-tab-btn.active{color:#a78bfa!important;border-bottom-color:#a78bfa}/* 搜索与全局增强基础 */.site-search-trigger{position:fixed;right:18px;top:82px;width:42px;height:42px;border:0;border-radius:50%;background:rgba(255,255,255,0.88);color:#0969da;box-shadow:0 8px 24px rgba(9,105,218,0.18);cursor:pointer;z-index:10001;display:flex;align-items:center;justify-content:center;font-size:18px;backdrop-filter:blur(10px);transition:transform .2s,box-shadow .2s}.site-search-panel{position:fixed;inset:0;z-index:10002;display:none;align-items:flex-start;justify-content:center;padding:80px 18px;background:rgba(27,31,36,.5);backdrop-filter:blur(8px)}.site-search-panel.is-open{display:flex}.site-search-box{width:min(720px,100%);max-height:min(760px,calc(100vh - 120px));overflow:hidden;border-radius:18px;background:#fff;box-shadow:0 24px 80px rgba(0,0,0,.28);border:1px solid rgba(9,105,218,.12)}.site-search-head{display:flex;align-items:center;gap:12px;padding:16px;border-bottom:1px solid rgba(9,105,218,.12)}.site-search-input{flex:1;min-width:0;border:0;outline:0;font-size:18px;line-height:1.5;background:transparent;color:#24292f}.site-search-close{border:0;background:transparent;color:#57606a;font-size:24px;line-height:1;cursor:pointer;padding:2px 6px}.site-search-results{max-height:560px;overflow:auto;padding:10px}.site-search-item{display:block;text-decoration:none;color:inherit;border-radius:12px;padding:12px 14px;border:1px solid transparent;transition:background .2s,border-color .2s,transform .2s}.site-search-item:hover{background:rgba(9,105,218,.06);border-color:rgba(9,105,218,.16);transform:translateY(-1px);text-decoration:none}.site-search-title{display:block;color:#0969da;font-weight:700;margin-bottom:5px}.site-search-desc{display:block;color:#57606a;font-size:13px;line-height:1.6}@media (max-width:760px){.toc,.markdown-toc,#markdown-toc{position:static!important;width:100%!important;max-height:260px!important;margin:12px 0!important}}</style><script>(function(){function ready(f){if(document.readyState!=='loading')f();else document.addEventListener('DOMContentLoaded',f)}function initSearch(){if(document.getElementById('site-search-btn'))return;var btn=document.createElement('button');btn.id='site-search-btn';btn.className='site-search-trigger';btn.innerHTML='🔍';document.body.appendChild(btn);var panel=document.createElement('div');panel.className='site-search-panel';panel.innerHTML='<div class=\"site-search-box\"><div class=\"site-search-head\">🔍 <input class=\"site-search-input\" placeholder=\"全局搜索文章...\"><button class=\"site-search-close\">×</button></div><div class=\"site-search-results\"></div></div>';document.body.appendChild(panel);var input=panel.querySelector('.site-search-input');var results=panel.querySelector('.site-search-results');var close=panel.querySelector('.site-search-close');btn.onclick=function(){panel.classList.add('is-open');input.focus()};close.onclick=function(){panel.classList.remove('is-open')};panel.onclick=function(e){if(e.target===panel)panel.classList.remove('is-open')};document.addEventListener('keydown',function(e){if(e.key==='/'&&document.activeElement!==input){e.preventDefault();panel.classList.add('is-open');input.focus()}if(e.key==='Escape')panel.classList.remove('is-open')});fetch('/postList.json').then(r=>r.json()).then(data=>{input.oninput=function(){var q=input.value.trim().toLowerCase();results.innerHTML='';if(!q)return;var match=data.filter(p=>p.title.toLowerCase().includes(q)||(p.desc&&p.desc.toLowerCase().includes(q)));if(match.length===0){results.innerHTML='<div class=\"site-search-empty\">未找到相关文章</div>';return}match.forEach(p=>{var item=document.createElement('a');item.className='site-search-item';item.href=p.link;item.innerHTML='<span class=\"site-search-title\">'+p.title+'</span><span class=\"site-search-desc\">'+(p.desc||'')+'</span>';results.appendChild(item)})}}).catch(()=>{results.innerHTML='<div class=\"site-search-empty\">索引加载失败</div>'})}ready(initSearch);/* ===== 首页增强（修复条件判断）===== */if(location.pathname==='/'||location.pathname==='/index.html'||location.pathname.endsWith('/')){var m=document.querySelector('.container-lg');if(m&&!document.querySelector('.announce-bar')){var a=document.createElement('div');a.className='announce-bar';a.innerHTML='📢 欢迎来到 Luliy 的博客！—— 记录点滴，我将无限进步！';m.insertBefore(a,m.firstChild);var hBar=document.createElement('div');hBar.className='hitokoto-bar';hBar.innerText='✨ 加载中... 一言金句';m.insertBefore(hBar,a.nextSibling);fetch('https://v1.hitokoto.cn').then(r=>r.json()).then(d=>{var from=d.from?d.from:'未知出处';hBar.innerText='“ '+d.hitokoto+' ” —— 《'+from+'》'}).catch(()=>{hBar.innerText='🌱 每一天都是新的进步'});}/* 樱花飘落 Canvas 特效系统（修复resize花瓣重置）*/var cvs=document.createElement('canvas');cvs.id='petals-canvas';document.body.insertBefore(cvs,document.body.firstChild);var ctx=cvs.getContext('2d');function initPetals(){var pNum=Math.min(35,Math.floor(window.innerWidth/40));var arr=[];for(var i=0;i<pNum;i++){arr.push({x:Math.random()*cvs.width,y:Math.random()*cvs.height,r:Math.random()*5+3,speed:Math.random()*0.8+0.4,drift:Math.random()*0.6-0.3,color:'rgba(255,183,197,'+(Math.random()*0.5+0.3)+')'})}return arr}var petals=initPetals();function resizeCanvas(){cvs.width=window.innerWidth;cvs.height=window.innerHeight;petals=initPetals()}window.addEventListener('resize',resizeCanvas);resizeCanvas();function drawPetals(){ctx.clearRect(0,0,cvs.width,cvs.height);petals.forEach(p=>{ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=p.color;ctx.fill();p.y+=p.speed;p.x+=p.drift;if(p.y>cvs.height){p.y=-10;p.x=Math.random()*cvs.width}});requestAnimationFrame(drawPetals)}drawPetals();}/* ===== 聚合单页 favorites（修复tab切换事件）===== */if(location.pathname.includes('favorites')){var pb=document.getElementById('postBody');if(pb){pb.innerHTML='<div class=\"fav-tabs\"><button class=\"fav-tab-btn active\" data-tab=\"archive\">📅 归档足迹</button><button class=\"fav-tab-btn\" data-tab=\"tools\">🛠️ 常用工具</button><button class=\"fav-tab-btn\" data-tab=\"prompts\">💡 提示词库</button></div><div id=\"fav-archive\" class=\"fav-tab-content\">正在构建时间轴...</div><div id=\"fav-tools\" class=\"fav-tab-content\" style=\"display:none;\"><ul style=\"line-height:2.2;padding-left:20px;\"><li>🔧 <a href=\"https://github.com/luliy6\" target=\"_blank\">GitHub Profile</a> - 个人代码主阵地</li><li>📝 <a href=\"https://ankiweb.net\" target=\"_blank\">AnkiWeb</a> - 英语学习终极记忆神器</li></ul></div><div id=\"fav-prompts\" class=\"fav-tab-content\" style=\"display:none;\"><ul style=\"line-height:2.2;padding-left:20px;\"><li>💡 <strong>CET-6 英语精读导师</strong>：专注于六级长难句剖析与语感建立的深度学习 Prompt。</li><li>💡 <strong>全栈自由职业发展规划</strong>：探索计算机技术与文学写作融合。</li></ul></div>';var btns=document.querySelectorAll('.fav-tab-btn');var contents={archive:document.getElementById('fav-archive'),tools:document.getElementById('fav-tools'),prompts:document.getElementById('fav-prompts')};function switchTab(tab){Object.keys(contents).forEach(t=>{contents[t].style.display='none'});if(contents[tab])contents[tab].style.display='block';btns.forEach(btn=>{if(btn.dataset.tab===tab)btn.classList.add('active');else btn.classList.remove('active')})}btns.forEach(btn=>{btn.addEventListener('click',function(e){switchTab(this.dataset.tab)})});fetch('/postList.json').then(r=>r.json()).then(posts=>{var byYear={};posts.forEach(p=>{var y=p.created?p.created.slice(0,4):'未知';if(!byYear[y])byYear[y]=[];byYear[y].push(p)});var html='<div style=\"border-left:2px solid #8250df;padding-left:18px;margin-top:15px;\">';Object.keys(byYear).sort((a,b)=>b-a).forEach(y=>{html+='<h3 style=\"color:#8250df;margin:16px 0 8px;\">'+y+'年</h3>';byYear[y].forEach(p=>{html+='<div style=\"margin:8px 0;font-size:14px;\"><span style=\"color:#888;margin-right:10px;\">['+p.created+']</span><a href=\"'+p.link+'\" style=\"color:#0969da;text-decoration:none;font-weight:bold;\">'+p.title+'</a></div>'})});html+='</div>';document.getElementById('fav-archive').innerHTML=html}).catch(()=>{document.getElementById('fav-archive').innerHTML='<p style=\"color:red\">归档加载失败</p>'})}}})();</script>",
  "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/lightbox.js'></script><script>document.addEventListener('DOMContentLoaded',function(){/* ===== 唯一 TOC 点击平滑滚动（修复冲突）===== */document.addEventListener('click',function(e){var anchor=e.target.closest('.toc a,.markdown-toc a,#markdown-toc a');if(anchor&&anchor.getAttribute('href')&&anchor.getAttribute('href').startsWith('#')){e.preventDefault();var rawId=anchor.getAttribute('href').substring(1);var targetId=decodeURIComponent(rawId);var targetEl=document.getElementById(targetId);if(!targetEl){var headings=document.querySelectorAll('#postBody h1,#postBody h2,#postBody h3');for(var i=0;i<headings.length;i++){if(headings[i].textContent.trim()===anchor.textContent.trim()){targetEl=headings[i];break}}}if(targetEl){var offset=targetEl.getBoundingClientRect().top+window.pageYOffset-80;window.scrollTo({top:offset,behavior:'smooth'});history.pushState(null,null,'#'+rawId)}}});/* ===== 顶部进度条 ===== */var bar=document.createElement('div');bar.style.cssText='position:fixed;top:0;left:0;height:3px;width:0%;background:#0969da;z-index:9999;transition:width 0.1s';document.body.appendChild(bar);/* ===== 回顶部按钮 + 阅读百分比 ===== */var progWrap=document.createElement('div');progWrap.style.cssText='position:fixed;bottom:24px;right:24px;width:52px;cursor:pointer;z-index:999;display:none;transition:transform 0.3s;text-align:center';progWrap.onmouseover=function(){this.style.transform='scale(1.1)'};progWrap.onmouseout=function(){this.style.transform='scale(1)'};progWrap.innerHTML='<svg viewBox=\"0 0 44 44\" style=\"width:44px;height:44px;transform:rotate(-90deg);border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.2);display:block;margin:0 auto\"><circle cx=\"22\" cy=\"22\" r=\"20\" fill=\"#fff\" stroke=\"#e8e8e8\" stroke-width=\"4\"></circle><circle id=\"prog-circ\" cx=\"22\" cy=\"22\" r=\"20\" fill=\"transparent\" stroke=\"#0969da\" stroke-width=\"4\" stroke-dasharray=\"125.6\" stroke-dashoffset=\"125.6\" stroke-linecap=\"round\" style=\"transition:stroke-dashoffset 0.1s\"></circle></svg><span style=\"position:absolute;top:11px;left:50%;transform:translateX(-50%);color:#0969da;font-size:12px;font-weight:bold;font-family:monospace\">↑</span><span id=\"prog-pct\" style=\"display:block;font-size:11px;color:#8250df;font-weight:bold;margin-top:3px;font-family:monospace\">0%</span>';document.body.appendChild(progWrap);progWrap.onclick=function(){window.scrollTo({top:0,behavior:'smooth'})};window.addEventListener('scroll',function(){var st=window.scrollY||document.documentElement.scrollTop;var dh=document.documentElement.scrollHeight-document.documentElement.clientHeight;var pct=dh>0?Math.round(st/dh*100):0;bar.style.width=pct+'%';if(st>300){progWrap.style.display='block';document.getElementById('prog-circ').style.strokeDashoffset=125.6-(125.6*pct/100);document.getElementById('prog-pct').textContent=pct+'%'}else{progWrap.style.display='none'}});/* ===== 代码语言标签 + 全屏按钮 + 复制按钮 ===== */document.querySelectorAll('pre').forEach(function(pre){var code=pre.querySelector('code');if(!code)return;pre.style.position='relative';var langMatch=(code.className||'').match(/language-(\\w+)/);if(langMatch){var tag=document.createElement('span');tag.textContent=langMatch[1];tag.style.cssText='position:absolute;top:8px;right:12px;font-size:11px;color:#888;font-family:monospace;text-transform:uppercase;background:#e8e8e8;padding:2px 8px;border-radius:4px';pre.appendChild(tag);}/* 复制按钮 */var copyBtn=document.createElement('button');copyBtn.textContent='复制';copyBtn.className='gmeek-copy-code';copyBtn.style.cssText='position:absolute;top:8px;right:80px;font-size:12px;color:#57606a;background:#e8e8e8;border:0;padding:2px 8px;border-radius:4px;cursor:pointer;z-index:2';copyBtn.onclick=function(){var text=code.innerText||code.textContent||'';if(navigator.clipboard&&window.isSecureContext){navigator.clipboard.writeText(text).then(function(){copyBtn.textContent='已复制';setTimeout(function(){copyBtn.textContent='复制'},1500)}).catch(function(){fallbackCopy(text,copyBtn)})}else{fallbackCopy(text,copyBtn)}};pre.appendChild(copyBtn);/* 全屏按钮 */var fsBtn=document.createElement('button');fsBtn.textContent='⛶';fsBtn.style.cssText='position:absolute;top:8px;right:140px;font-size:13px;color:#888;background:#e8e8e8;border:none;padding:2px 8px;border-radius:4px;cursor:pointer';fsBtn.onclick=function(){if(!document.fullscreenElement){pre.requestFullscreen()}else{document.exitFullscreen()}};pre.appendChild(fsBtn);function fallbackCopy(text,btn){var ta=document.createElement('textarea');ta.value=text;ta.style.cssText='position:fixed;left:-9999px;top:-9999px';document.body.appendChild(ta);ta.select();document.execCommand('copy');ta.remove();btn.textContent='已复制';setTimeout(function(){btn.textContent='复制'},1500)}});/* ===== 外链新标签 ===== */document.querySelectorAll('a[href^=\"http\"]').forEach(function(a){if(!a.href.includes(location.hostname))a.target='_blank'});/* ===== 文章阅读统计 ===== */var pbody=document.getElementById('postBody');if(pbody){var wc=pbody.innerText.length;var mins=Math.max(1,Math.round(wc/300));var rtag=document.createElement('p');rtag.innerHTML='📖 预计阅读：约 '+mins+' 分钟 &nbsp;|&nbsp; 共 '+wc+' 字';rtag.style.cssText='color:#888;font-size:13px;margin-bottom:1.5rem';pbody.insertBefore(rtag,pbody.firstChild);}});</script>",
  "style": "#postBody h2{border-left:4px solid #0969da;padding-left:10px;background:rgba(9,105,218,0.04);padding-top:6px;padding-bottom:6px}#postBody strong,#postBody a{color:#f0b429}#postBody blockquote{position:relative;padding-left:40px!important}#postBody blockquote::before{content:'“';font-size:50px;position:absolute;left:10px;top:-10px;color:#8250df;opacity:0.3}",
