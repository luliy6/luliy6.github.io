  "script": "<script>document.addEventListener('DOMContentLoaded',function(){function initArticle(){var postBody=document.getElementById('postBody');if(!postBody)return;var progress=document.createElement('div');progress.id='gmeek-progress';progress.style.cssText='position:fixed;top:0;left:0;height:3px;width:0%;background:linear-gradient(90deg,#0969da,#8250df);z-index:9999;transition:width .1s';document.body.appendChild(progress);function updateProgress(){var st=window.scrollY||document.documentElement.scrollTop;var dh=document.documentElement.scrollHeight-document.documentElement.clientHeight;progress.style.width=(dh>0?Math.min(100,Math.max(0,st/dh*100)):0)+'%'}window.addEventListener('scroll',updateProgress,{passive:true});updateProgress();postBody.querySelectorAll('a[href^=\"http\"]').forEach(function(a){if(!a.href.includes(location.host))a.target='_blank'});postBody.querySelectorAll('img').forEach(function(img){img.loading='lazy';var caption=(img.alt||img.title||'').trim();var parent=img.parentElement;var standalone=false;var anchor=null;if(parent&&parent.tagName==='A'&&parent.children.length===1&&parent.firstElementChild===img){anchor=parent;standalone=!!(anchor.parentElement&&anchor.parentElement.tagName==='P'&&anchor.parentElement.children.length===1)}else if(parent&&parent.tagName==='P'&&parent.children.length===1&&parent.firstElementChild===img){standalone=true}if(standalone){var figure=document.createElement('figure');figure.className='post-figure is-loading';var skel=document.createElement('div');skel.className='post-img-skel';figure.appendChild(skel);if(anchor){figure.appendChild(anchor);}else{figure.appendChild(img);}if(caption){var fc=document.createElement('figcaption');fc.textContent=caption;figure.appendChild(fc)}(anchor&&anchor.parentElement?anchor.parentElement:parent).replaceWith(figure);var done=function(){figure.classList.remove('is-loading')};if(img.complete){done()}else{img.addEventListener('load',done,{once:true});img.addEventListener('error',done,{once:true})}}else{img.style.cursor='zoom-in'}});postBody.querySelectorAll('pre').forEach(function(pre){var code=pre.querySelector('code');if(!code)return;var lines=(code.textContent||'').split(/\\r?\\n/).length;var cls=(code.className||'');var m=cls.match(/language-([\\w-]+)/);if(m){var tag=document.createElement('span');tag.textContent=m[1];tag.style.cssText='position:absolute;top:10px;left:12px;font-size:11px;color:#6b7280;font-family:monospace;text-transform:uppercase;background:rgba(255,255,255,.78);padding:2px 8px;border-radius:999px;z-index:2';pre.style.position='relative';pre.appendChild(tag)}if(lines>20){pre.classList.add('is-collapsed');var btn=document.createElement('button');btn.type='button';btn.className='code-toggle-btn';btn.textContent='展开代码';btn.onclick=function(){var collapsed=pre.classList.toggle('is-collapsed');btn.textContent=collapsed?'展开代码':'收起代码'};pre.appendChild(btn)}});postBody.querySelectorAll('h1,h2,h3').forEach(function(h){if(!h.id)return;h.style.cursor='pointer';h.title='点击复制链接';h.addEventListener('click',function(){var url=location.href.split('#')[0]+'#'+h.id;navigator.clipboard&&navigator.clipboard.writeText(url)})});var share=document.createElement('div');share.className='share-box';var title=(document.querySelector('#postBody h1')||{}).textContent||document.title;var pageUrl=location.href.split('#')[0];var shareText=encodeURIComponent(title+' '+pageUrl);var weiboUrl='https://service.weibo.com/share/share.php?url='+encodeURIComponent(pageUrl)+'&title='+encodeURIComponent(title);var twitterUrl='https://twitter.com/intent/tweet?text='+shareText+'&url='+encodeURIComponent(pageUrl);share.innerHTML='<div class=\"share-title\">分享本文</div><div class=\"share-actions\"><button type=\"button\" class=\"share-copy\">复制链接</button><a class=\"share-weibo\" target=\"_blank\" rel=\"noopener noreferrer\">微博</a><a class=\"share-twitter\" target=\"_blank\" rel=\"noopener noreferrer\">Twitter</a></div>';share.querySelector('.share-copy').onclick=function(){navigator.clipboard&&navigator.clipboard.writeText(pageUrl).then(function(){share.querySelector('.share-copy').textContent='已复制'}).catch(function(){prompt('复制链接',pageUrl)})};share.querySelector('.share-weibo').href=weiboUrl;share.querySelector('.share-twitter').href=twitterUrl;postBody.insertAdjacentElement('afterend',share)}function initTagCloud(){var isTagPage=/tag/i.test(location.pathname)||document.querySelector('.tag-cloud,.tag-list,.tag-list-page,.tag-item');if(!isTagPage)return;var links=Array.from(document.querySelectorAll('.tag-cloud a,.tag-list a,a[href*=\"/tag/\"]'));if(!links.length)return;var maxCount=1;var items=links.map(function(a){var text=(a.textContent||'').trim();var count=1;var m=(a.dataset&&a.dataset.count&&String(a.dataset.count).match(/\\d+/))||text.match(/\\((\\d+)\\)$/)||text.match(/(\\d+)$/);if(m)count=parseInt(m[1]||m[0],10)||1;maxCount=Math.max(maxCount,count);return{a:a,count:count}});items.forEach(function(item){var size=12+Math.round((item.count/maxCount)*12);item.a.style.fontSize=size+'px';item.a.style.fontWeight=item.count===maxCount?'700':'500';item.a.style.display='inline-block';item.a.style.margin='.35rem .45rem';item.a.style.padding='.45rem .75rem';item.a.style.borderRadius='999px';item.a.style.background='rgba(9,105,218,.08)';item.a.style.transition='transform .2s ease,background .2s ease';item.a.onmouseenter=function(){item.a.style.transform='translateY(-2px)';item.a.style.background='rgba(9,105,218,.14)'};item.a.onmouseleave=function(){item.a.style.transform='translateY(0)';item.a.style.background='rgba(9,105,218,.08)'}})}initArticle();initTagCloud()});</script>",
  "style": "<style>#postBody{font-size:18px;line-height:1.9;max-width:860px;counter-reset:h2count}#postBody h1,#postBody h2,#postBody h3,#postBody h4{background:linear-gradient(90deg,#0969da,#8250df,#d1248d,#0969da);background-size:220% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;animation:rainbowShift 10s linear infinite}#postBody h2{counter-increment:h2count}#postBody h2::before{content:counter(h2count) '. ';color:#8250df;font-weight:700}#postBody a{color:#8250df;text-decoration:none}#postBody a:hover{text-decoration:underline}#postBody img{display:block;margin:0 auto;max-width:100%;height:auto;border-radius:10px;box-shadow:0 6px 20px rgba(0,0,0,.08)}.post-figure{margin:1.2rem auto;text-align:center}.post-figure figcaption{margin-top:.55rem;font-size:.92rem;line-height:1.5;color:#6b7280}.post-figure.is-loading img{opacity:0}.post-img-skel{display:none;min-height:160px;border-radius:10px;background:linear-gradient(90deg,rgba(0,0,0,.04) 25%,rgba(0,0,0,.08) 37%,rgba(0,0,0,.04) 63%);background-size:400% 100%;animation:skelMove 1.3s ease infinite}.post-figure.is-loading .post-img-skel{display:block}@keyframes skelMove{0%{background-position:100% 50%}100%{background-position:0 50%}}#postBody pre{position:relative;background:#f6f8fa;border-radius:12px;padding:16px;overflow:hidden}#postBody pre code{background:none;padding:0;font-size:.92em}#postBody pre.is-collapsed{max-height:520px}#postBody pre.is-collapsed::after{content:'';position:absolute;left:0;right:0;bottom:0;height:90px;background:linear-gradient(to bottom,rgba(246,248,250,0),rgba(246,248,250,.95))}.code-toggle-btn{position:absolute;top:10px;right:12px;z-index:2;font-size:12px;border:none;border-radius:999px;padding:4px 10px;background:#0969da;color:#fff;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.12)}.share-box{margin-top:2rem;padding:1rem 1.1rem;border:1px solid #e5e7eb;border-radius:14px;background:rgba(255,255,255,.7);backdrop-filter:blur(6px)}.share-title{font-weight:700;margin-bottom:.75rem}.share-actions{display:flex;flex-wrap:wrap;gap:.6rem}.share-actions button,.share-actions a{border:1px solid #d0d7de;background:#fff;color:#24292f;border-radius:999px;padding:.52rem .95rem;text-decoration:none;cursor:pointer;font-size:.92rem}.share-actions button:hover,.share-actions a:hover{border-color:#0969da;color:#0969da}</style>",
  "indexStyle": "<style>.blogTitle h1,.blogTitle a,.blogTitle p{animation:rainbowShift 8s linear infinite;background:linear-gradient(90deg,#ff4d6d,#ff9f1c,#2ec4b6,#3a86ff,#8338ec,#ff4d6d);background-size:300% 100%;-webkit-background-clip:text;background-clip:text;color:transparent}.home-announce{position:sticky;top:0;z-index:60;margin:0 0 1rem;padding:.85rem 1rem;border:1px solid #e5e7eb;border-radius:14px;background:rgba(255,255,255,.84);backdrop-filter:blur(8px);box-shadow:0 8px 24px rgba(0,0,0,.06)}.home-announce strong{margin-right:.45rem}.home-announce a{color:#0969da;text-decoration:none}.home-announce a:hover{text-decoration:underline}.post-item{transition:box-shadow .2s,transform .2s;border-radius:10px;padding:10px 14px}.post-item:hover{box-shadow:0 4px 18px rgba(0,0,0,.10);transform:translateY(-2px)}.footer{text-align:center;font-size:13px;color:#888;margin-top:2rem;padding-top:1rem;border-top:1px solid #eee}@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}.post-item{animation:fadeInUp .5s ease both}canvas#petals-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}.color-fg-muted.mt-2{display:none}</style>",
