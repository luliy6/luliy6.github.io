  "allHead": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekVercount.js'></script><link rel='stylesheet' href='https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css'><style>body,#postBody{font-family:'LXGW WenKai','LXGW WenKai Screen',sans-serif}html{scroll-behavior:smooth}::selection{background:#ff000033;color:#e03030}a[target='_blank']::after{content:' ↗';font-size:0.75em;opacity:0.6}</style>",
  "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script src='https://blog.meekdai.com/Gmeek/plugins/lightbox.js'></script><script>document.addEventListener('DOMContentLoaded',function(){var bar=document.createElement('div');bar.style.cssText='position:fixed;top:0;left:0;height:3px;width:0%;background:linear-gradient(90deg,#0969da,#8250df);z-index:9999;transition:width 0.1s';document.body.appendChild(bar);window.addEventListener('scroll',function(){var st=window.scrollY||document.documentElement.scrollTop;var dh=document.documentElement.scrollHeight-document.documentElement.clientHeight;bar.style.width=(dh>0?Math.round(st/dh*100):0)+'%'});document.querySelectorAll('pre').forEach(function(pre){var code=pre.querySelector('code');if(!code)return;var m=(code.className||'').match(/language-(\\w+)/);if(!m)return;var tag=document.createElement('span');tag.textContent=m[1];tag.style.cssText='position:absolute;top:8px;right:12px;font-size:11px;color:#888;font-family:monospace;text-transform:uppercase;background:#e8e8e8;padding:2px 8px;border-radius:4px';pre.style.position='relative';pre.appendChild(tag);var fsBtn=document.createElement('button');fsBtn.textContent='⛶';fsBtn.title='全屏展开';fsBtn.style.cssText='position:absolute;top:8px;right:80px;font-size:13px;color:#888;background:#e8e8e8;border:none;padding:2px 8px;border-radius:4px;cursor:pointer';fsBtn.onclick=function(){if(!document.fullscreenElement){pre.requestFullscreen()}else{document.exitFullscreen()}};pre.appendChild(fsBtn)});document.querySelectorAll('a[href^=\"http\"]').forEach(function(a){if(!a.href.includes('luliy6.github.io'))a.target='_blank'});document.querySelectorAll('#postBody img').forEach(function(img){img.loading='lazy'});var pbody=document.getElementById('postBody');if(pbody){var wc=pbody.innerText.length;var mins=Math.max(1,Math.round(wc/300));var rtag=document.createElement('p');rtag.innerHTML='预计阅读：约 '+mins+' 分钟 &nbsp;|&nbsp; 共 '+wc+' 字';rtag.style.cssText='color:#888;font-size:13px;margin-bottom:1.5rem';pbody.insertBefore(rtag,pbody.firstChild);document.querySelectorAll('#postBody h1,#postBody h2,#postBody h3').forEach(function(h){h.style.cursor='pointer';h.title='点击复制链接';h.onclick=function(){var url=location.href.split('#')[0]+'#'+h.id;navigator.clipboard&&navigator.clipboard.writeText(url);var tip=document.createElement('span');tip.textContent=' 已复制!';tip.style.cssText='font-size:12px;color:#1f883d;font-weight:normal';h.appendChild(tip);setTimeout(function(){tip.remove()},2000)}})}var topBtn=document.createElement('button');topBtn.textContent='↑';topBtn.style.cssText='position:fixed;bottom:24px;right:24px;width:44px;height:44px;border-radius:50%;border:none;background:#0969da;color:#fff;font-size:20px;cursor:pointer;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2);display:none;transition:opacity 0.3s';document.body.appendChild(topBtn);topBtn.onclick=function(){window.scrollTo({top:0,behavior:'smooth'})};window.addEventListener('scroll',function(){topBtn.style.display=window.scrollY>300?'block':'none'});var searchBtn=document.createElement('button');searchBtn.textContent='S';searchBtn.title='搜索文章';searchBtn.style.cssText='position:fixed;bottom:80px;right:24px;width:44px;height:44px;border-radius:50%;border:none;background:#8250df;color:#fff;font-size:15px;font-weight:bold;cursor:pointer;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2)';document.body.appendChild(searchBtn);var overlay=document.createElement('div');overlay.style.cssText='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:1000;align-items:flex-start;justify-content:center;padding-top:80px';overlay.innerHTML='<div style=\"background:#fff;border-radius:12px;padding:20px;width:90%;max-width:500px\"><input id=\"s-input\" placeholder=\"搜索文章...\" style=\"width:100%;padding:10px;font-size:16px;border:1px solid #ddd;border-radius:8px;outline:none\"><div id=\"s-results\" style=\"margin-top:12px;max-height:400px;overflow-y:auto\"></div></div>';document.body.appendChild(overlay);searchBtn.onclick=function(){overlay.style.display='flex';setTimeout(function(){document.getElementById('s-input').focus()},100)};overlay.onclick=function(e){if(e.target===overlay)overlay.style.display='none'};document.getElementById('s-input').addEventListener('input',function(){var q=this.value.trim().toLowerCase();var res=document.getElementById('s-results');if(!q){res.innerHTML='';return}fetch('/postList.json').then(function(r){return r.json()}).then(function(posts){var hits=posts.filter(function(p){return p.title.toLowerCase().includes(q)});res.innerHTML=hits.length?hits.map(function(p){return'<a href=\"'+p.link+'\" style=\"display:block;padding:10px;border-bottom:1px solid #eee;color:#0969da;text-decoration:none\">'+p.title+'</a>'}).join(''):'<p style=\"color:#888;padding:10px\">没有找到相关文章</p>'})})});</script>",
  "style": "<style>#postBody{font-size:18px;line-height:1.9;max-width:860px}#postBody h1,#postBody h2,#postBody h3,#postBody h4{color:#0969da}#postBody a{color:#8250df;text-decoration:none}#postBody a:hover{text-decoration:underline}#postBody img{display:block;margin:0 auto;max-width:100%;border-radius:8px}#postBody pre{background:#f6f8fa;border-radius:10px;padding:16px;overflow-x:auto}#postBody code{background:#f0f0f0;border-radius:4px;padding:2px 6px;font-size:0.9em}#postBody pre code{background:none;padding:0}.avatar{cursor:pointer;animation:none!important;transform:none!important}</style>",
  "indexStyle": "<style>.post-item{transition:box-shadow 0.2s,transform 0.2s;border-radius:10px;padding:10px 14px}.post-item:hover{box-shadow:0 4px 18px rgba(0,0,0,0.10);transform:translateY(-2px)}.footer{text-align:center;font-size:13px;color:#888;margin-top:2rem;padding-top:1rem;border-top:1px solid #eee}@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}.post-item{animation:fadeInUp 0.5s ease both}canvas#petals-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}.color-fg-muted.mt-2{display:none}</style>",
  "head": "",
  "indexScript": "<script>document.addEventListener('DOMContentLoaded',function(){var av=document.querySelector('.avatar');if(av){av.style.cursor='pointer';av.onclick=function(){window.open('https://github.com/luliy6')}}var items=document.querySelectorAll('.post-item');items.forEach(function(el,i){el.style.animationDelay=(i*0.07)+'s'});var el=document.querySelector('.blogTitle p')||document.querySelector('p.f4');if(el){var txt=el.textContent;el.textContent='';var i=0;(function type(){if(i<txt.length){el.textContent+=txt[i++];setTimeout(type,60)}})()}var canvas=document.createElement('canvas');canvas.id='petals-canvas';document.body.appendChild(canvas);var ctx=canvas.getContext('2d');canvas.width=window.innerWidth;canvas.height=window.innerHeight;window.addEventListener('resize',function(){canvas.width=window.innerWidth;canvas.height=window.innerHeight});var petals=[];for(var p=0;p<38;p++){petals.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:Math.random()*7+4,speed:Math.random()*1.2+0.4,drift:Math.random()*0.8-0.4,opacity:Math.random()*0.5+0.3,color:Math.random()>0.5?'#ffb7c5':'#fff'})}function drawPetal(p){ctx.save();ctx.globalAlpha=p.opacity;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=p.color;ctx.fill();ctx.restore()}function animatePetals(){ctx.clearRect(0,0,canvas.width,canvas.height);petals.forEach(function(p){drawPetal(p);p.y+=p.speed;p.x+=p.drift;if(p.y>canvas.height+10){p.y=-10;p.x=Math.random()*canvas.width}});requestAnimationFrame(animatePetals)}animatePetals();document.addEventListener('click',function(e){for(var b=0;b<18;b++){var spark=document.createElement('div');var angle=Math.random()*360;var dist=Math.random()*60+20;var colors=['#ff6b9d','#ffcd3c','#6bceff','#a78bfa','#34d399'];spark.style.cssText='position:fixed;left:'+e.clientX+'px;top:'+e.clientY+'px;width:7px;height:7px;border-radius:50%;background:'+colors[Math.floor(Math.random()*colors.length)]+';pointer-events:none;z-index:9999;transition:transform 0.6s ease,opacity 0.6s ease;transform:translate(-50%,-50%)';document.body.appendChild(spark);setTimeout(function(s,a,d){s.style.transform='translate(calc(-50% + '+Math.cos(a*Math.PI/180)*d+'px),calc(-50% + '+Math.sin(a*Math.PI/180)*d+'px))';s.style.opacity='0'})(spark,angle,dist,0);setTimeout(function(s){s.remove()}(spark),700)}})});</script>"
