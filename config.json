  "indexScript": "<script>document.addEventListener('DOMContentLoaded',function(){var av=document.querySelector('.avatar');if(av){av.style.cursor='pointer';av.onclick=function(){window.open('https://github.com/luliy6')}}var items=document.querySelectorAll('.post-item');items.forEach(function(el,i){el.style.animationDelay=(i*0.07)+'s'});var el=document.querySelector('.blogTitle p')||document.querySelector('p.f4');if(el){var txt=el.textContent;el.textContent='';var i=0;(function type(){if(i<txt.length){el.textContent+=txt[i++];setTimeout(type,60)}})()}window.effectsEnabled=true;var canvas=document.createElement('canvas');canvas.id='petals-canvas';document.body.appendChild(canvas);var ctx=canvas.getContext('2d');canvas.width=window.innerWidth;canvas.height=window.innerHeight;window.addEventListener('resize',function(){canvas.width=window.innerWidth;canvas.height=window.innerHeight});var petals=[];for(var p=0;p<38;p++){petals.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:Math.random()*7+4,speed:Math.random()*1.2+0.4,drift:Math.random()*0.8-0.4,opacity:Math.random()*0.5+0.3,color:Math.random()>0.5?'#ffb7c5':'#fff'})}function drawPetal(p){ctx.save();ctx.globalAlpha=p.opacity;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=p.color;ctx.fill();ctx.restore()}var animId;function animatePetals(){if(!window.effectsEnabled)return;ctx.clearRect(0,0,canvas.width,canvas.height);petals.forEach(function(p){drawPetal(p);p.y+=p.speed;p.x+=p.drift;if(p.y>canvas.height+10){p.y=-10;p.x=Math.random()*canvas.width}});animId=requestAnimationFrame(animatePetals)}animatePetals();document.addEventListener('click',function(e){if(!window.effectsEnabled||e.target.tagName==='BUTTON'||e.target.tagName==='INPUT'||e.target.closest('#s-results'))return;for(var b=0;b<18;b++){var spark=document.createElement('div');var angle=Math.random()*360;var dist=Math.random()*60+20;var colors=['#ff6b9d','#ffcd3c','#6bceff','#a78bfa','#34d399'];spark.style.cssText='position:fixed;left:'+e.clientX+'px;top:'+e.clientY+'px;width:7px;height:7px;border-radius:50%;background:'+colors[Math.floor(Math.random()*colors.length)]+';pointer-events:none;z-index:9999;transition:transform 0.6s ease,opacity 0.6s ease;transform:translate(-50%,-50%)';document.body.appendChild(spark);setTimeout(function(s,a,d){s.style.transform='translate(calc(-50% + '+Math.cos(a*Math.PI/180)*d+'px),calc(-50% + '+Math.sin(a*Math.PI/180)*d+'px))';s.style.opacity='0'})(spark,angle,dist,0);setTimeout(function(s){s.remove()}(spark),700)}});var toggleBtn=document.createElement('button');toggleBtn.innerHTML='✨ 关开特效';toggleBtn.style.cssText='position:fixed;bottom:24px;right:24px;padding:8px 15px;border-radius:20px;border:none;background:#8250df;color:#fff;font-size:14px;cursor:pointer;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,0.2);transition:all 0.3s';document.body.appendChild(toggleBtn);toggleBtn.onclick=function(e){e.stopPropagation();window.effectsEnabled=!window.effectsEnabled;if(window.effectsEnabled){toggleBtn.style.background='#8250df';toggleBtn.style.opacity='1';animatePetals()}else{toggleBtn.style.background='#888';toggleBtn.style.opacity='0.6';cancelAnimationFrame(animId);ctx.clearRect(0,0,canvas.width,canvas.height)}};var searchBtn=document.createElement('button');searchBtn.innerHTML='🔍 搜索 (Ctrl+K)';searchBtn.style.cssText='position:fixed;bottom:70px;right:24px;padding:8px 15px;border-radius:20px;border:none;background:#0969da;color:#fff;font-size:14px;cursor:pointer;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,0.2)';document.body.appendChild(searchBtn);var overlay=document.createElement('div');overlay.style.cssText='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:10000;align-items:flex-start;justify-content:center;padding-top:100px;backdrop-filter:blur(3px)';overlay.innerHTML='<div style=\"background:#fff;border-radius:12px;padding:20px;width:90%;max-width:500px;box-shadow:0 10px 25px rgba(0,0,0,0.2)\"><input id=\"s-input\" placeholder=\"输入关键词搜索文章...\" style=\"width:100%;padding:12px;font-size:16px;border:1px solid #ddd;border-radius:8px;outline:none;box-sizing:border-box\"><div id=\"s-results\" style=\"margin-top:12px;max-height:400px;overflow-y:auto\"></div><div style=\"text-align:right;margin-top:10px;font-size:12px;color:#888\">按 ESC 关闭</div></div>';document.body.appendChild(overlay);function openSearch(){overlay.style.display='flex';setTimeout(function(){document.getElementById('s-input').focus()},100)}function closeSearch(){overlay.style.display='none'}searchBtn.onclick=function(e){e.stopPropagation();openSearch()};overlay.onclick=function(e){if(e.target===overlay)closeSearch()};document.addEventListener('keydown',function(e){if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='k'){e.preventDefault();openSearch()}if(e.key==='Escape'&&overlay.style.display==='flex'){closeSearch()}});document.getElementById('s-input').addEventListener('input',function(){var q=this.value.trim();var res=document.getElementById('s-results');if(!q){res.innerHTML='';return}var qLower=q.toLowerCase();fetch('/postList.json').then(function(r){return r.json()}).then(function(posts){var hits=posts.filter(function(p){return p.title.toLowerCase().includes(qLower)});if(hits.length){var safeQ=q.replace(/[.*+?^${}()|\\[\\]\\\\]/g,'\\\\$&');var regex=new RegExp('('+safeQ+')','gi');res.innerHTML=hits.map(function(p){var hlTitle=p.title.replace(regex,'<mark style=\"background:#fff8c5;color:#bc4c00;border-radius:2px;padding:0 2px\">$1</mark>');return'<a href=\"'+p.link+'\" style=\"display:block;padding:10px;border-bottom:1px solid #eee;color:#0969da;text-decoration:none;font-size:16px\">'+hlTitle+'</a>'}).join('')}else{res.innerHTML='<p style=\"color:#888;padding:10px;text-align:center\">没有找到相关文章</p>'}}).catch(function(){res.innerHTML='<p style=\"color:red;padding:10px;text-align:center\">搜索加载失败</p>'})});});</script>"
